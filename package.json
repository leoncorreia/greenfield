{
  "name": "greenfield-vendor-ops",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build -w apps/server && npm run build -w apps/web",
    "dev": "concurrently \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "dev:server": "npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "test": "npm run test -w apps/server",
    "lint": "npm run lint -w apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
