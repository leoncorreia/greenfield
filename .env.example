# --- Core ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
REDIS_URL=redis://127.0.0.1:6379
PUBLIC_BASE_URL=http://127.0.0.1:8080
# On Render, omit PUBLIC_BASE_URL to use RENDER_EXTERNAL_URL (set by the platform).
CITED_MD_PATH=./cited.md
# Serve built UI from the API (one URL). Example after `npm run build -w apps/web`:
# STATIC_WEB_ROOT=apps/web/dist
STATIC_WEB_ROOT=

# Correlation / run defaults
AUTO_START_RUN=false

# --- Web discovery (Tinyfish-style pipeline; off = mock vendors only) ---
WEB_DISCOVERY_ENABLED=false
WEB_DISCOVERY_MAX_PAGES=10
WEB_DISCOVERY_RATE_MS=750
WEB_DISCOVERY_SEED_URLS=

# --- LLM (Milestone 4: vendor ranking + cited.md; negotiation later) ---
# none = deterministic heuristic; openai = OpenAI API; gmi = GMI Cloud (OpenAI-compatible); bedrock = AWS Converse
LLM_PROVIDER=none
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# GMI Cloud Inference Engine — https://docs.gmicloud.ai/inference-engine/api-reference/llm-api-reference
# Same protocol as OpenAI: POST {GMI_BASE_URL}/chat/completions (default base https://api.gmi-serving.com/v1)
GMI_API_KEY=
GMI_BASE_URL=
GMI_MODEL=
AWS_REGION=
AWS_BEDROCK_MODEL_ID=
# Standard AWS credential chain for Bedrock (e.g. AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY on Render)

# --- Optional integrations (no-op if unset) ---
NEXLA_API_KEY=
NEXLA_BASE_URL=
GHOST_ADMIN_API_KEY=
GHOST_CONTENT_API_URL=
TIGERDATA_DATABASE_URL=

# --- Payment rail stubs (never commit real secrets) ---
X402_ENDPOINT=
CDP_ENDPOINT=
MPP_ENDPOINT=
AGENTIC_MARKET_ENDPOINT=

# --- Web (Vite; production build) ---
# Set when the UI is built against a remote API (e.g. Render). Dev uses Vite proxy /api.
# VITE_API_ORIGIN=https://your-service.onrender.com

# --- Tests ---
RUN_INTEGRATION_TESTS=false
